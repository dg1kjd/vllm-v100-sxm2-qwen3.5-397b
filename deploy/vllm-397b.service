[Unit]
Description=vLLM Qwen3.5-397B-A17B AWQ (SM70 TP8, 8x Tesla V100-SXM2)
After=network-online.target nvidia-persistenced.service
Wants=network-online.target nvidia-persistenced.service
# Reroll budget for the KV-fit memory draw: up to 5 starts / 10 min, then quiet.
StartLimitIntervalSec=600
StartLimitBurst=5

[Service]
Type=exec
# Set these to the account that owns the venv + model weights:
User=YOUR_SERVICE_USER
Group=YOUR_SERVICE_USER
# Any dir OUTSIDE the source checkout (its vllm/ shadows the installed package):
WorkingDirectory=/path/to/workdir
# Copy deploy/vllm-397b.env.example here and edit it:
EnvironmentFile=/path/to/vllm-397b.env

ExecStart=/path/to/.venv/bin/python -m vllm.entrypoints.openai.api_server \
  --model ${VLLM_397B_MODEL} \
  --served-model-name Qwen3.5-397B-A17B-AWQ \
  --attention-backend FLASH_ATTN_V100 \
  --tensor-parallel-size 8 \
  --gpu-memory-utilization ${VLLM_397B_GPU_MEM_UTIL} \
  --kv-cache-dtype fp8_e5m2 \
  --max-model-len ${VLLM_397B_MAX_MODEL_LEN} \
  --max-num-seqs ${VLLM_397B_MAX_NUM_SEQS} \
  --max-num-batched-tokens ${VLLM_397B_MAX_BATCHED_TOKENS} \
  --compilation-config '{"cudagraph_capture_sizes":[1,2,4,8]}' \
  --enable-prefix-caching \
  --no-async-scheduling \
  --mamba-ssm-cache-dtype float32 \
  --skip-mm-profiling \
  --enable-auto-tool-choice --tool-call-parser qwen3_coder \
  --reasoning-parser qwen3 \
  --default-chat-template-kwargs '{"enable_thinking": true}' \
  --override-generation-config '{"thinking_token_budget": ${VLLM_397B_THINK_BUDGET}}' \
  --trust-remote-code --host 0.0.0.0 --port ${VLLM_397B_PORT}

# Restart=always (not on-failure): a worker OOM can take the engine down via a
# CLEAN (exit 0) API-server shutdown, which on-failure would NOT catch. always
# still does not restart on an explicit `systemctl stop` (manual GPU free).
Restart=always
RestartSec=20
# Model load runs in the active state; never kill a slow load as a start timeout.
TimeoutStartSec=infinity
# Let NCCL/KV tear down cleanly; control-group kill reaps all 8 TP workers.
TimeoutStopSec=180
KillMode=control-group
KillSignal=SIGTERM
FinalKillSignal=SIGKILL

# Headroom for TP8 (fds, pinned mem). vLLM uses /dev/shm - do NOT set PrivateTmp.
LimitNOFILE=1048576
LimitMEMLOCK=infinity
OOMScoreAdjust=-200

[Install]
WantedBy=multi-user.target
