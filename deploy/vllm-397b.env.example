# vLLM 397B service config. Copy to /path/to/vllm-397b.env, edit, then:
#   sudo systemctl restart vllm-397b

# ---- ExecStart-referenced tunables ----
VLLM_397B_PORT=8000
VLLM_397B_MAX_MODEL_LEN=140000
VLLM_397B_MAX_NUM_SEQS=8
VLLM_397B_MAX_BATCHED_TOKENS=1059
VLLM_397B_GPU_MEM_UTIL=0.95
VLLM_397B_MODEL=/path/to/Qwen3.5-397B-A17B-AWQ
# Server-side default thinking budget: forces </think> after N reasoning tokens so
# reasoning-mode loops can't run away to empty output. Clients override per-request
# with "thinking_token_budget". -1 = unlimited (disables the guard).
VLLM_397B_THINK_BUDGET=4096

# ---- process env ----
# SM70 MoE temp-buffer fragmentation OOM mitigation: proactively reclaim cached
# blocks when reserved memory crosses 0.8 of the pool, so a fresh ~84MiB cudaMalloc
# finds contiguous space. (expandable_segments is known-broken for this profile.)
PYTORCH_CUDA_ALLOC_CONF=garbage_collection_threshold:0.8
TORCH_BLAS_PREFER_CUBLASLT=1
VLLM_USE_FLASHINFER_SAMPLER=0
NCCL_DEBUG=WARN
NCCL_MAX_NCHANNELS=2
NCCL_MIN_NCHANNELS=1
NCCL_BUFFSIZE=1048576
CUBLAS_WORKSPACE_CONFIG=:16:8
FLASHINFER_DISABLE_VERSION_CHECK=1
# GDN Volta autotune (the ~1.5 GiB/rank reclaim) - leave as shipped:
VLLM_SM70_GDN_DELTA_H_BV=16
VLLM_SM70_GDN_DELTA_H_WARPS=4
VLLM_SM70_GDN_DELTA_H_STAGES=1
VLLM_SM70_GDN_CHUNK_O_BK=64
VLLM_SM70_GDN_CHUNK_O_BV=64
VLLM_SM70_GDN_CHUNK_O_WARPS=8
VLLM_SM70_GDN_CHUNK_O_STAGES=2
VLLM_SM70_FP16_GUARD=1
VLLM_SM70_GDN_DECODE_FLASHQLA=0
# Decode-corruption guard (auto-armed by this fork for non-MTP; set here too):
VLLM_SM70_QWEN_GDN_FULL_FORWARD=1
